PORT=3000
NODE_ENV=development

# SQLite database path (use /data/ops.db on Render with persistent disk)
DB_PATH=./data/ops.db

# VAPID keys for web push — auto-generated on first run if blank
# After first run, copy the printed keys here so they persist across restarts
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:your@email.com
