{
  "version": 2,
  "builds": [
    { "src": "server.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "/server.js" }
  ],
  "env": {
    "NODE_ENV": "production",
    "DB_PATH": "/tmp/ops.db"
  },
  "crons": [
    { "path": "/api/cron/nudge", "schedule": "* * * * *" }
  ]
}
